{
  "_note": "ABL 실제 충원요청서(Personnel Request Form) 양식 기반. 요구자격 6개 항목은 비워두면 detail 페이지에서 자동 숨김 처리됩니다.",
  "form_title": "직원충원요청서 (Personnel Request Form)",
  "form_subtitle": "현업 부서의 인재 요구사항을 작성해주세요.",

  "sections": [
    {
      "id": "basic",
      "title": "기본 정보",
      "icon": "ti-info-circle",
      "fields": [
        {"id": "office", "label": "본부 (Office)", "type": "text", "placeholder": "예: 마케팅본부", "required": true},
        {"id": "dept", "label": "팀 (Department)", "type": "text", "placeholder": "예: 마케팅팀", "required": true},
        {"id": "position", "label": "채용 직무 (Job Position)", "type": "text", "placeholder": "예: 디지털 마케팅 매니저", "required": true},
        {"id": "level", "label": "직급", "type": "select", "options": ["사원", "대리", "과장", "차장", "부장"], "required": true},
        {"id": "type", "label": "채용 유형", "type": "radio", "options": ["신입", "경력"], "required": true},
        {"id": "headcount", "label": "필요 인원 (Required #)", "type": "number", "placeholder": "1", "required": true},
        {"id": "desired_date", "label": "입사 요청일 (Required date)", "type": "date", "required": false},
        {"id": "employment_type", "label": "고용형태 (Type of Employment)", "type": "select", "options": ["정규직", "계약직", "임시직", "Outsourced worker", "Others"], "required": true}
      ]
    },
    {
      "id": "reason",
      "title": "충원 사유 (Reason for Personnel Request)",
      "icon": "ti-file-text",
      "fields": [
        {"id": "reason_category", "label": "충원 사유 구분", "type": "select", "options": ["결원 충원", "신규 사업", "조직 확대", "인력 보강", "기타"], "required": true},
        {"id": "reason_detail", "label": "채용 요청 사유 상세", "type": "textarea", "placeholder": "채용 요청 사유에 대해 상세하게 기재해주세요 (Please specify reasons in detail justifying personnel request)", "required": true}
      ]
    },
    {
      "id": "job",
      "title": "주요업무 (Job Description)",
      "icon": "ti-briefcase",
      "fields": [
        {"id": "main_duties", "label": "담당 업무", "type": "textarea", "placeholder": "이 포지션이 수행할 핵심 업무를 자유롭게 작성해주세요.", "required": true}
      ]
    },
    {
      "id": "qualifications",
      "title": "요구자격 (Required Qualifications)",
      "icon": "ti-user-check",
      "section_hint": "해당하는 항목만 작성해주세요. 비워둔 항목은 자동으로 표시되지 않습니다.",
      "fields": [
        {"id": "qual_technical", "label": "Technical Knowledge (기술 지식)", "type": "textarea", "placeholder": "예: GA4, A/B 테스트 도구, SQL 등", "required": false, "ai_expand": true},
        {"id": "qual_education", "label": "Educational Background (학력)", "type": "textarea", "placeholder": "예: 학사 이상, 마케팅·통계·경영 관련 전공 우대", "required": false, "ai_expand": true},
        {"id": "qual_experience", "label": "Job Experience (경력)", "type": "textarea", "placeholder": "예: 디지털 마케팅 3년 이상 실무 경력", "required": false, "ai_expand": true},
        {"id": "qual_language", "label": "Language Skill (어학)", "type": "textarea", "placeholder": "예: 영어 비즈니스 커뮤니케이션 가능", "required": false, "ai_expand": true},
        {"id": "qual_certification", "label": "Certification (자격증)", "type": "textarea", "placeholder": "예: Google Analytics 4 자격증, 데이터 분석 관련 자격증", "required": false, "ai_expand": true},
        {"id": "qual_competencies", "label": "Competencies (역량)", "type": "textarea", "placeholder": "예: 데이터 기반 의사결정, 가설 검증 사고, 협업 커뮤니케이션", "required": false, "ai_expand": true}
      ]
    },
    {
      "id": "talent",
      "title": "ABL 인재상 및 우대사항",
      "icon": "ti-user-star",
      "section_hint": "ABL 5대 핵심가치와 우대 역량을 선택해주세요.",
      "fields": [
        {"id": "core_values", "label": "ABL 5대 핵심가치 중 우선순위 (최대 2개)", "type": "checkbox", "options": ["배려", "든든함", "전문성", "스마트", "선진"], "max": 2, "required": true},
        {"id": "key_skills", "label": "핵심 우대 역량 (최대 5개)", "type": "tags", "placeholder": "예: 데이터 분석, A/B 테스트 (Enter로 추가)", "max": 5},
        {"id": "preferred_qual", "label": "기타 우대사항", "type": "textarea", "placeholder": "있으면 좋은 추가 역량·경험을 자유롭게 작성", "required": false},
        {"id": "etc", "label": "기타 요구사항", "type": "textarea", "placeholder": "면접 시 강조하고 싶은 점, 특별한 요구사항 등 자유롭게 작성", "required": false}
      ]
    }
  ],

  "approval_flow": {
    "_note": "ABL 양식의 3단계 결재 구조를 간소화하여 표시",
    "stages": [
      {"id": "requester", "label": "Requested by Head of Dept.", "label_ko": "요청 부서장", "type": "auto"},
      {"id": "hr_consent", "label": "HR Consent", "label_ko": "인사팀 검토", "type": "auto"},
      {"id": "approved", "label": "Approved by Head of Office", "label_ko": "본부장 최종 승인", "type": "auto"}
    ]
  }
}
